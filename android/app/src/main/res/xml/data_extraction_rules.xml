<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules (Android 12+).

  Required by the Android 12+ Auto Backup and Device-to-Device transfer APIs.
  Same policy as backup_rules.xml: NOTHING is included in either path. The
  user's recovery data is too sensitive to ride along with a Google account
  transfer or a phone-to-phone copy. Users restore manually via Settings.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
