  "homeQuote0": "Every sober day is an act of love for your future self.",
  "@homeQuote0": {},
  "homeQuote1": "You do not have to feel ready. You only have to begin.",
  "@homeQuote1": {},
  "homeQuote2": "Healing is allowed to be quiet.",
  "@homeQuote2": {},
  "homeQuote3": "One calm choice can change the shape of a day.",
  "@homeQuote3": {},
  "homeQuote4": "You are not starting over. You are starting wiser.",
  "@homeQuote4": {},
  "homeQuote5": "Recovery is not linear, but it is still real.",
  "@homeQuote5": {},
  "homeQuote6": "Even a difficult sober day is proof that you are choosing yourself.",
  "@homeQuote6": {},
  "homeQuote7": "The version of you that kept going is still here.",
  "@homeQuote7": {},
  "homeQuote8": "Strength can look like softness.",
  "@homeQuote8": {},
  "homeQuote9": "Clarity is built one honest moment at a time.",
  "@homeQuote9": {},
  "homeQuote10": "You have survived hard days before. Today can be held gently too.",
  "@homeQuote10": {},
  "homeQuote11": "Cravings are temporary. Your progress is still here.",
  "@homeQuote11": {},
  "homeQuote12": "Each morning is another chance to care for yourself.",
  "@homeQuote12": {},
  "homeQuote13": "Progress does not need to be perfect to be meaningful.",
  "@homeQuote13": {},
  "homeQuote14": "You are becoming someone you can trust.",
  "@homeQuote14": {},
  "homeQuote15": "Small choices become a safer life.",
  "@homeQuote15": {},
  "homeQuote16": "Peace is not rushed. It is practised.",
  "@homeQuote16": {},
  "homeQuote17": "You are allowed to outgrow what once numbed you.",
  "@homeQuote17": {},
  "homeQuote18": "The urge will pass. Your dignity can remain.",
  "@homeQuote18": {},
  "homeQuote19": "Recovery is a return to yourself.",
  "@homeQuote19": {},
  "homeQuote20": "You are not behind. You are healing at human speed.",
  "@homeQuote20": {},
  "homeQuote21": "A softer life is still a strong life.",
  "@homeQuote21": {},
  "homeQuote22": "Your future self is being protected by today's choices.",
  "@homeQuote22": {},
  "homeQuote23": "You can pause. You can breathe. You can choose again.",
  "@homeQuote23": {},
  "homeQuote24": "Every honest day is part of the way forward.",
  "@homeQuote24": {},
  "homeQuote25": "You do not need to punish yourself to change.",
  "@homeQuote25": {},
  "homeQuote26": "The quiet work counts.",
  "@homeQuote26": {},
  "homeQuote27": "Your nervous system is learning safety again.",
  "@homeQuote27": {},
  "homeQuote28": "You are worthy of care before you feel strong.",
  "@homeQuote28": {},
  "homeQuote29": "Let today be simple. Let today be enough.",
  "@homeQuote29": {},
  "homeQuote30": "One breath can become one minute. One minute can become one day.",
  "@homeQuote30": {},
  "homeQuote31": "You are not your craving. You are the one witnessing it.",
  "@homeQuote31": {},
  "homeQuote32": "You can build a life that no longer asks you to escape it.",
  "@homeQuote32": {},
  "homeQuote33": "There is strength in staying.",
  "@homeQuote33": {},
  "homeQuote34": "Healing begins where shame loses its voice.",
  "@homeQuote34": {},
  "homeQuote35": "You are allowed to need support.",
  "@homeQuote35": {},
  "homeQuote36": "The path forward can be gentle and still be powerful.",
  "@homeQuote36": {},
  "homeQuote37": "Your progress is not erased by a hard moment.",
  "@homeQuote37": {},
  "homeQuote38": "Choose the next right thing, not the perfect thing.",
  "@homeQuote38": {},
  "homeQuote39": "Sobriety is not a punishment. It is protection.",
  "@homeQuote39": {},
  "homeQuote40": "You are learning how to come home to yourself.",
  "@homeQuote40": {},
  "homeQuote41": "The life you want is built in ordinary moments.",
  "@homeQuote41": {},
  "homeQuote42": "You can be proud without being finished.",
  "@homeQuote42": {},
  "homeQuote43": "Nothing about healing needs to be loud to be real.",
  "@homeQuote43": {},
  "homeQuote44": "Your peace is worth protecting.",
  "@homeQuote44": {},
  "homeQuote45": "A craving is a wave, not a command.",
  "@homeQuote45": {},
  "homeQuote46": "You are building evidence that you can trust yourself.",
  "@homeQuote46": {},
  "homeQuote47": "Today does not need to be conquered. It only needs to be lived.",
  "@homeQuote47": {},
  "homeQuote48": "There is still time to become someone new.",
  "@homeQuote48": {},
  "homeQuote49": "Keep going gently. That still counts.",
  "@homeQuote49": {},
  "homeMission0": "Drink a full glass of water slowly.",
  "@homeMission0": {},
