  "@homeMission28": {},
  "homeMission29": "Choose a meal that supports your energy.",
  "@homeMission29": {},
  "homeMission30": "Read one recovery note or affirmation.",
  "@homeMission30": {},
  "homeMission31": "Save one emergency support number somewhere visible.",
  "@homeMission31": {},
  "homeMission32": "Write a short note to your future self.",
  "@homeMission32": {},
  "homeMission33": "Take a gentle shower or bath.",
  "@homeMission33": {},
  "homeMission34": "Breathe through a craving without judging it.",
  "@homeMission34": {},
  "homeMission35": "Name the emotion underneath the urge.",
  "@homeMission35": {},
  "homeMission36": "Do one thing slowly on purpose.",
  "@homeMission36": {},
  "homeMission37": "Put clean water beside your bed.",
  "@homeMission37": {},
  "homeMission38": "Open a window and take three deep breaths.",
  "@homeMission38": {},
  "homeMission39": "Write down one reason you are continuing.",
  "@homeMission39": {},
  "homeMission40": "Spend five minutes in natural light.",
  "@homeMission40": {},
  "homeMission41": "Make your bed with care.",
  "@homeMission41": {},
  "homeMission42": "Delete or mute one digital trigger.",
  "@homeMission42": {},
  "homeMission43": "Choose rest before exhaustion.",
  "@homeMission43": {},
  "homeMission44": "Write one sentence that begins: \"Today I protected…\"",
  "@homeMission44": {},
  "homeMission45": "Notice one moment of peace, however small.",
  "@homeMission45": {},
  "homeMission46": "Thank yourself for staying present.",
  "@homeMission46": {},
  "homeMission47": "Do a 10-minute reset of your space.",
  "@homeMission47": {},
  "homeMission48": "Choose one boundary that supports your recovery.",
