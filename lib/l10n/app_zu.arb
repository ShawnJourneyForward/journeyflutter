  "homeMission15": "Step outside and notice the sky.",
  "@homeMission15": {},
  "homeMission16": "Say \"I am allowed to heal\" three times.",
  "@homeMission16": {},
  "homeMission17": "Make yourself something warm to drink.",
  "@homeMission17": {},
  "homeMission18": "Reach out to your support network.",
  "@homeMission18": {},
  "homeMission19": "Honour the progress you have made today.",
  "@homeMission19": {},
  "homeMission20": "Take five slow breaths before your next decision.",
  "@homeMission20": {},
  "homeMission21": "Write down one trigger you noticed today.",
  "@homeMission21": {},
  "homeMission22": "Write down one thing that helped you today.",
  "@homeMission22": {},
  "homeMission23": "Place one comforting item near your bed.",
  "@homeMission23": {},
  "homeMission24": "Wash your face slowly and mindfully.",
  "@homeMission24": {},
  "homeMission25": "Spend 10 minutes away from screens.",
  "@homeMission25": {},
  "homeMission26": "Prepare tomorrow's first small task.",
  "@homeMission26": {},
  "homeMission27": "Let one room feel a little lighter.",
