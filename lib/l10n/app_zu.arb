  "privacyTitle": "Privacy Policy",
  "@privacyTitle": {},
  "privacyAbsoluteHeadline": "Your privacy is absolute.",
  "@privacyAbsoluteHeadline": {},
  "privacyCommitment": "Journey Forward stores everything on your device only. No data is ever sent to any server.",
  "@privacyCommitment": {},
  "privacyAllDataOnDevice": "All data stays on your device",
  "@privacyAllDataOnDevice": {},
  "privacyAllDataOnDeviceBody": "Every piece of information you enter — your sober date, journal entries, gratitude notes, slip records, and profile — is stored locally on your device using the operating system's standard app storage. Nothing is transmitted to any external server, cloud service, or third party at any time.",
  "@privacyAllDataOnDeviceBody": {},
  "privacyNoInternet": "No internet connection required",
  "@privacyNoInternet": {},
  "privacyNoInternetBody": "Journey Forward works fully offline. All fonts and assets are bundled inside the app. The app makes no network requests of any kind — no internet connection is needed or used.",
  "@privacyNoInternetBody": {},
  "privacyNoAnalytics": "No analytics or tracking",
  "@privacyNoAnalytics": {},
  "privacyNoAnalyticsBody": "There are no analytics SDKs, crash reporters, or usage trackers in this app. We do not collect any data about how you use the app, how often you open it, or what features you use.",
  "@privacyNoAnalyticsBody": {},
  "privacyEmergencyContacts": "Emergency contacts",
  "@privacyEmergencyContacts": {},
  "privacyEmergencyContactsBody": "If you add an emergency contact, their name and phone number are stored only on your device as part of your profile. This information is never shared, synced, or backed up automatically.",
  "@privacyEmergencyContactsBody": {},
  "privacyBackupRestore": "Backup & restore",
  "@privacyBackupRestore": {},
  "privacyBackupRestoreBody": "When you export a backup, a JSON file is created and shared via your device's share sheet — the same way you share photos. Journey Forward does not receive or store this file. You control where it goes.",
  "@privacyBackupRestoreBody": {},
  "privacyPINBiometric": "PIN and biometric lock",
  "@privacyPINBiometric": {},
  "privacyPINBiometricBody": "If you enable a PIN, it is stored as a SHA-256 hash in your device's secure encrypted storage — never as plaintext. Biometric unlock uses your device's native biometric system and Journey Forward never accesses or stores biometric data.",
  "@privacyPINBiometricBody": {},
  "privacyHowToDelete": "How to delete your data",
  "@privacyHowToDelete": {},
  "privacyHowToDeleteBody": "To permanently delete all your data, simply uninstall the app. All data stored by Journey Forward is removed when the app is uninstalled. There is no account to delete because there is no account — only data on your device.",
  "@privacyHowToDeleteBody": {},
  "privacyChildrenPrivacy": "Children's privacy",
  "@privacyChildrenPrivacy": {},
  "privacyChildrenPrivacyBody": "Journey Forward is designed for adults aged 18 and over. The app is not directed at children and does not knowingly collect any information from anyone under the age of 18.",
  "@privacyChildrenPrivacyBody": {},
  "privacyPolicyUpdates": "Policy updates",
  "@privacyPolicyUpdates": {},
  "privacyPolicyUpdatesBody": "If this privacy policy changes, the update will be included in a new app version. Since we collect no data, changes will only reflect improvements in transparency or new features added to the app.",
  "@privacyPolicyUpdatesBody": {}
