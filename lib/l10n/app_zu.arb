  "cbtGuide0Title": "Challenge the Thought",
  "@cbtGuide0Title": {},
  "cbtGuide0Step0": "Write down the thought that's troubling you.",
  "@cbtGuide0Step0": {},
  "cbtGuide0Step1": "Ask: Is this thought based on fact or feeling?",
  "@cbtGuide0Step1": {},
  "cbtGuide0Step2": "What evidence supports this thought? What contradicts it?",
  "@cbtGuide0Step2": {},
  "cbtGuide0Step3": "What would you say to a friend having this thought?",
  "@cbtGuide0Step3": {},
  "cbtGuide0Step4": "Write a more balanced version of the thought.",
  "@cbtGuide0Step4": {},
  "cbtGuide0Step5": "Notice how you feel after reframing it.",
  "@cbtGuide0Step5": {},
  "cbtGuide1Title": "Surf the Urge",
  "@cbtGuide1Title": {},
  "cbtGuide1Step0": "Recognise the urge — name it: \"I notice a craving.\"",
  "@cbtGuide1Step0": {},
  "cbtGuide1Step1": "Don't fight it. Observe it like a wave.",
  "@cbtGuide1Step1": {},
  "cbtGuide1Step2": "Notice where you feel it in your body.",
  "@cbtGuide1Step2": {},
  "cbtGuide1Step3": "Breathe slowly. The wave will peak and pass.",
  "@cbtGuide1Step3": {},
  "cbtGuide1Step4": "Remind yourself: urges always pass within 20–30 minutes.",
  "@cbtGuide1Step4": {},
  "cbtGuide2Title": "Cost-Benefit Check",
  "@cbtGuide2Title": {},
  "cbtGuide2Step0": "List the short-term benefits of drinking.",
  "@cbtGuide2Step0": {},
  "cbtGuide2Step1": "List the short-term costs of drinking.",
  "@cbtGuide2Step1": {},
  "cbtGuide2Step2": "List the long-term benefits of staying sober.",
  "@cbtGuide2Step2": {},
  "cbtGuide2Step3": "List the long-term costs of drinking.",
  "@cbtGuide2Step3": {},
  "cbtGuide2Step4": "Which column weighs more to your future self?",
  "@cbtGuide2Step4": {},
  "cbtGuide3Title": "Trigger Action Plan",
  "@cbtGuide3Title": {},
  "cbtGuide3Step0": "Identify the trigger: person, place, feeling, or time.",
  "@cbtGuide3Step0": {},
  "cbtGuide3Step1": "What has worked before in similar moments?",
  "@cbtGuide3Step1": {},
  "cbtGuide3Step2": "Who can you call or text right now?",
  "@cbtGuide3Step2": {},
  "cbtGuide3Step3": "What activity can you do for the next 20 minutes?",
  "@cbtGuide3Step3": {},
  "cbtGuide3Step4": "Write your commitment: \"When X happens, I will Y.\"",
  "@cbtGuide3Step4": {},
  "cbtGuide4Title": "Identity Shift",
  "@cbtGuide4Title": {},
  "cbtGuide4Step0": "Describe the person you are becoming.",
  "@cbtGuide4Step0": {},
  "cbtGuide4Step1": "What values guide that person?",
  "@cbtGuide4Step1": {},
  "cbtGuide4Step2": "What would that person do right now?",
  "@cbtGuide4Step2": {},
  "cbtGuide4Step3": "Write: \"I am someone who...\"",
  "@cbtGuide4Step3": {},
  "cbtGuide4Step4": "Act from that identity for the next hour.",
  "@cbtGuide4Step4": {},
