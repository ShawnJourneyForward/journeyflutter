  "journalAffirm0": "I am worthy of love and belonging.",
  "@journalAffirm0": {},
  "journalAffirm1": "I choose recovery every single day.",
  "@journalAffirm1": {},
  "journalAffirm2": "My past does not define my future.",
  "@journalAffirm2": {},
  "journalAffirm3": "I am getting stronger with each passing moment.",
  "@journalAffirm3": {},
  "journalAffirm4": "I deserve peace, health, and happiness.",
  "@journalAffirm4": {},
  "journalAffirm5": "I am proud of how far I have come.",
  "@journalAffirm5": {},
