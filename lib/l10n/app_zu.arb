  "@homeMission2": {},
  "homeMission3": "Send a kind message to someone you trust.",
  "@homeMission3": {},
  "homeMission4": "Do five minutes of slow breathing.",
  "@homeMission4": {},
  "homeMission5": "Read a few pages of something calming.",
  "@homeMission5": {},
  "homeMission6": "Eat one nourishing meal without distractions.",
  "@homeMission6": {},
  "homeMission7": "Prepare for an earlier, softer night.",
  "@homeMission7": {},
  "homeMission8": "Do one kind thing for yourself today.",
  "@homeMission8": {},
  "homeMission9": "Sit in silence for three minutes.",
  "@homeMission9": {},
  "homeMission10": "Write one honest sentence in your journal.",
  "@homeMission10": {},
  "homeMission11": "Put your phone away for one quiet hour.",
  "@homeMission11": {},
  "homeMission12": "Stretch your shoulders, neck, and back.",
  "@homeMission12": {},
  "homeMission13": "Listen to music that steadies you.",
  "@homeMission13": {},
  "homeMission14": "Tidy one small area of your space.",
