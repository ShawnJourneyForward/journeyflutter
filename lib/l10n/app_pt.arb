  "meditationUrgeSurfingTitle": "Urge Surfing",
  "@meditationUrgeSurfingTitle": {"description": "Title of the Urge Surfing guided meditation."},
  "meditationUrgeSurfingStep0": "Close your eyes and take three slow breaths.",
  "@meditationUrgeSurfingStep0": {"description": "Urge Surfing meditation step 1 of 7."},
  "meditationUrgeSurfingStep1": "Notice the craving. Where do you feel it in your body?",
  "@meditationUrgeSurfingStep1": {"description": "Urge Surfing meditation step 2 of 7."},
  "meditationUrgeSurfingStep2": "Imagine it as a wave in the ocean — rising slowly.",
  "@meditationUrgeSurfingStep2": {"description": "Urge Surfing meditation step 3 of 7. Keep the em dash."},
  "meditationUrgeSurfingStep3": "You are a surfer. You don't fight the wave. You ride it.",
  "@meditationUrgeSurfingStep3": {"description": "Urge Surfing meditation step 4 of 7."},
  "meditationUrgeSurfingStep4": "Watch the wave peak. It cannot go higher than it already is.",
  "@meditationUrgeSurfingStep4": {"description": "Urge Surfing meditation step 5 of 7."},
  "meditationUrgeSurfingStep5": "Now watch it begin to fall. Urges always fade.",
  "@meditationUrgeSurfingStep5": {"description": "Urge Surfing meditation step 6 of 7."},
  "meditationUrgeSurfingStep6": "You did not drink. The wave passed. You surfed it.",
  "@meditationUrgeSurfingStep6": {"description": "Urge Surfing meditation step 7 of 7."},
  "meditationBodyScanTitle": "Body Scan",
  "@meditationBodyScanTitle": {"description": "Title of the Body Scan guided meditation."},
  "meditationBodyScanStep0": "Lie down or sit comfortably. Close your eyes.",
  "@meditationBodyScanStep0": {"description": "Body Scan meditation step 1 of 7."},
  "meditationBodyScanStep1": "Bring attention to your feet. Notice any sensation — warmth, tingling.",
  "@meditationBodyScanStep1": {"description": "Body Scan meditation step 2 of 7. Keep the em dash."},
  "meditationBodyScanStep2": "Slowly move up to your calves, then knees, then thighs.",
  "@meditationBodyScanStep2": {"description": "Body Scan meditation step 3 of 7."},
  "meditationBodyScanStep3": "Notice your belly rising and falling with each breath.",
  "@meditationBodyScanStep3": {"description": "Body Scan meditation step 4 of 7."},
  "meditationBodyScanStep4": "Scan your chest, shoulders, arms, and hands.",
  "@meditationBodyScanStep4": {"description": "Body Scan meditation step 5 of 7."},
  "meditationBodyScanStep5": "Finally, relax your jaw, eyes, and forehead.",
  "@meditationBodyScanStep5": {"description": "Body Scan meditation step 6 of 7."},
  "meditationBodyScanStep6": "Rest here for a moment. You are safe. You are whole.",
  "@meditationBodyScanStep6": {"description": "Body Scan meditation step 7 of 7."},
  "meditationGratitudeResetTitle": "Gratitude Reset",
  "@meditationGratitudeResetTitle": {"description": "Title of the Gratitude Reset guided meditation."},
  "meditationGratitudeResetStep0": "Sit quietly. Take three slow breaths.",
  "@meditationGratitudeResetStep0": {"description": "Gratitude Reset meditation step 1 of 7."},
  "meditationGratitudeResetStep1": "Think of one person in your life you're grateful for.",
  "@meditationGratitudeResetStep1": {"description": "Gratitude Reset meditation step 2 of 7."},
  "meditationGratitudeResetStep2": "What did they do or say that mattered to you?",
  "@meditationGratitudeResetStep2": {"description": "Gratitude Reset meditation step 3 of 7."},
  "meditationGratitudeResetStep3": "Think of one moment from today, however small, that was good.",
  "@meditationGratitudeResetStep3": {"description": "Gratitude Reset meditation step 4 of 7."},
  "meditationGratitudeResetStep4": "Think of something about your body or health you appreciate.",
  "@meditationGratitudeResetStep4": {"description": "Gratitude Reset meditation step 5 of 7."},
  "meditationGratitudeResetStep5": "Let gratitude fill your chest like warmth.",
  "@meditationGratitudeResetStep5": {"description": "Gratitude Reset meditation step 6 of 7."},
  "meditationGratitudeResetStep6": "Carry this feeling into your next hour.",
  "@meditationGratitudeResetStep6": {"description": "Gratitude Reset meditation step 7 of 7."},
  "meditationSafePlaceTitle": "Safe Place",
  "@meditationSafePlaceTitle": {"description": "Title of the Safe Place guided meditation."},
  "meditationSafePlaceStep0": "Close your eyes. Take three slow, deep breaths.",
  "@meditationSafePlaceStep0": {"description": "Safe Place meditation step 1 of 7."},
  "meditationSafePlaceStep1": "Imagine a place where you feel completely safe.",
  "@meditationSafePlaceStep1": {"description": "Safe Place meditation step 2 of 7."},
  "meditationSafePlaceStep2": "It can be real or imagined — a beach, a forest, a room.",
  "@meditationSafePlaceStep2": {"description": "Safe Place meditation step 3 of 7. Keep the em dash."},
  "meditationSafePlaceStep3": "Notice what you see, hear, smell in this place.",
  "@meditationSafePlaceStep3": {"description": "Safe Place meditation step 4 of 7."},
  "meditationSafePlaceStep4": "Feel the ground beneath you. You are supported.",
  "@meditationSafePlaceStep4": {"description": "Safe Place meditation step 5 of 7."},
  "meditationSafePlaceStep5": "Breathe here for a while. Nothing can harm you.",
  "@meditationSafePlaceStep5": {"description": "Safe Place meditation step 6 of 7."},
  "meditationSafePlaceStep6": "When you're ready, slowly return, carrying this calm.",
  "@meditationSafePlaceStep6": {"description": "Safe Place meditation step 7 of 7."},
  "meditationSelfCompassionTitle": "Self-Compassion",
  "@meditationSelfCompassionTitle": {"description": "Title of the Self-Compassion guided meditation."},
  "meditationSelfCompassionStep0": "Place your hand on your heart. Feel its warmth.",
  "@meditationSelfCompassionStep0": {"description": "Self-Compassion meditation step 1 of 7."},
  "meditationSelfCompassionStep1": "Say: \"This is a moment of difficulty.\"",
  "@meditationSelfCompassionStep1": {"description": "Self-Compassion meditation step 2 of 7. Keep the quotation marks."},
  "meditationSelfCompassionStep2": "Say: \"Difficulty is part of life. I am not alone in this.\"",
  "@meditationSelfCompassionStep2": {"description": "Self-Compassion meditation step 3 of 7. Keep the quotation marks."},
  "meditationSelfCompassionStep3": "Say: \"May I be kind to myself right now.\"",
  "@meditationSelfCompassionStep3": {"description": "Self-Compassion meditation step 4 of 7. Keep the quotation marks."},
  "meditationSelfCompassionStep4": "Think of something you've been critical of yourself about.",
  "@meditationSelfCompassionStep4": {"description": "Self-Compassion meditation step 5 of 7."},
  "meditationSelfCompassionStep5": "Ask: what would I say to a dear friend in this situation?",
  "@meditationSelfCompassionStep5": {"description": "Self-Compassion meditation step 6 of 7."},
  "meditationSelfCompassionStep6": "Say those words to yourself. You deserve them too.",
  "@meditationSelfCompassionStep6": {"description": "Self-Compassion meditation step 7 of 7."}
}
