  "zenQuote0": "The present moment is the only time over which we have dominion.",
  "@zenQuote0": {},
  "zenQuoteAuthor0": "Thich Nhat Hanh",
  "@zenQuoteAuthor0": {},
  "zenQuote1": "You don't have to control your thoughts. You just have to stop letting them control you.",
  "@zenQuote1": {},
  "zenQuoteAuthor1": "Dan Millman",
  "@zenQuoteAuthor1": {},
  "zenQuote2": "Peace is not the absence of conflict, but the ability to cope with it.",
  "@zenQuote2": {},
  "zenQuoteAuthor2": "Mahatma Gandhi",
  "@zenQuoteAuthor2": {},
  "zenQuote3": "Recovery is not a race. You don't have to feel guilty if it takes you longer than you thought it would.",
  "@zenQuote3": {},
  "zenQuoteAuthor3": "Anonymous",
  "@zenQuoteAuthor3": {},
  "zenQuote4": "Every day is a new beginning. Take a deep breath, smile, and start again.",
  "@zenQuote4": {},
  "zenQuoteAuthor4": "Anonymous",
  "@zenQuoteAuthor4": {},
  "zenQuote5": "The wound is the place where the Light enters you.",
  "@zenQuote5": {},
  "zenQuoteAuthor5": "Rumi",
  "@zenQuoteAuthor5": {},
  "zenQuote6": "You are enough just as you are.",
  "@zenQuote6": {},
  "zenQuoteAuthor6": "Meghan Markle",
  "@zenQuoteAuthor6": {},
  "zenQuote7": "Healing is not linear.",
  "@zenQuote7": {},
  "zenQuoteAuthor7": "Anonymous",
  "@zenQuoteAuthor7": {},
  "zenQuote8": "What lies behind us and what lies before us are tiny matters compared to what lies within us.",
  "@zenQuote8": {},
  "zenQuoteAuthor8": "Ralph Waldo Emerson",
  "@zenQuoteAuthor8": {},
  "zenQuote9": "You have been assigned this mountain to show others it can be moved.",
  "@zenQuote9": {},
  "zenQuoteAuthor9": "Mel Robbins",
  "@zenQuoteAuthor9": {},
  "zenQuote10": "It does not matter how slowly you go as long as you do not stop.",
  "@zenQuote10": {},
  "zenQuoteAuthor10": "Confucius",
  "@zenQuoteAuthor10": {},
  "zenQuote11": "The hardest step she ever took was to blindly trust in who she was.",
  "@zenQuote11": {},
  "zenQuoteAuthor11": "Atticus",
  "@zenQuoteAuthor11": {},
  "zenQuote12": "One day at a time — this is enough. Do not look back and grieve over the past, for it is gone.",
  "@zenQuote12": {},
  "zenQuoteAuthor12": "Ida Scott Taylor",
  "@zenQuoteAuthor12": {},
  "zenQuote13": "Rock bottom became the solid foundation on which I rebuilt my life.",
  "@zenQuote13": {},
  "zenQuoteAuthor13": "J.K. Rowling",
  "@zenQuoteAuthor13": {},
  "zenQuote14": "Be patient with yourself. You are a child of the universe.",
  "@zenQuote14": {},
  "zenQuoteAuthor14": "Max Ehrmann",
  "@zenQuoteAuthor14": {},
  "zenQuote15": "In the middle of every difficulty lies opportunity.",
  "@zenQuote15": {},
  "zenQuoteAuthor15": "Albert Einstein",
  "@zenQuoteAuthor15": {},
  "zenQuote16": "Your present circumstances don't determine where you can go; they merely determine where you start.",
  "@zenQuote16": {},
  "zenQuoteAuthor16": "Nido Qubein",
  "@zenQuoteAuthor16": {},
  "zenQuote17": "The secret of getting ahead is getting started.",
  "@zenQuote17": {},
  "zenQuoteAuthor17": "Mark Twain",
  "@zenQuoteAuthor17": {},
  "zenQuote18": "You are braver than you believe, stronger than you seem, and smarter than you think.",
  "@zenQuote18": {},
  "zenQuoteAuthor18": "A.A. Milne",
  "@zenQuoteAuthor18": {},
  "zenQuote19": "Don't watch the clock; do what it does. Keep going.",
  "@zenQuote19": {},
  "zenQuoteAuthor19": "Sam Levenson",
  "@zenQuoteAuthor19": {},
  "zenQuote20": "Accept yourself, love yourself, and keep moving forward.",
  "@zenQuote20": {},
  "zenQuoteAuthor20": "Roy T. Bennett",
  "@zenQuoteAuthor20": {},
  "zenQuote21": "The journey of a thousand miles begins with one step.",
  "@zenQuote21": {},
  "zenQuoteAuthor21": "Lao Tzu",
  "@zenQuoteAuthor21": {},
  "zenQuote22": "You can't go back and change the beginning, but you can start where you are and change the ending.",
  "@zenQuote22": {},
  "zenQuoteAuthor22": "C.S. Lewis",
  "@zenQuoteAuthor22": {},
  "zenQuote23": "Strength does not come from physical capacity. It comes from an indomitable will.",
  "@zenQuote23": {},
  "zenQuoteAuthor23": "Mahatma Gandhi",
  "@zenQuoteAuthor23": {},
  "zenQuote24": "Every moment is a fresh beginning.",
  "@zenQuote24": {},
  "zenQuoteAuthor24": "T.S. Eliot",
  "@zenQuoteAuthor24": {},
  "zenQuote25": "Just when the caterpillar thought the world was ending, he turned into a butterfly.",
  "@zenQuote25": {},
  "zenQuoteAuthor25": "Proverb",
  "@zenQuoteAuthor25": {},
  "zenQuote26": "Courage doesn't always roar. Sometimes courage is the quiet voice at the end of the day saying, I will try again tomorrow.",
  "@zenQuote26": {},
  "zenQuoteAuthor26": "Mary Anne Radmacher",
  "@zenQuoteAuthor26": {},
  "zenQuote27": "The only way out is through.",
  "@zenQuote27": {},
  "zenQuoteAuthor27": "Robert Frost",
  "@zenQuoteAuthor27": {},
  "zenQuote28": "You are not your past. You are the lessons you've learned from it.",
  "@zenQuote28": {},
  "zenQuoteAuthor28": "Anonymous",
  "@zenQuoteAuthor28": {},
  "zenQuote29": "Progress, not perfection.",
  "@zenQuote29": {},
  "zenQuoteAuthor29": "Anonymous",
  "@zenQuoteAuthor29": {},
