  "recoveryM1Label": "12 Hours",
  "@recoveryM1Label": {},
  "recoveryM1Title": "The Reset Begins",
  "@recoveryM1Title": {},
  "recoveryM1Body": "Your body begins adjusting to the absence of alcohol. Hydration, sleep pressure, blood sugar, and stress hormones may feel unsettled as your system begins to rebalance.",
  "@recoveryM1Body": {},
  "recoveryM1System": "Total Body",
  "@recoveryM1System": {},
  "recoveryM2Label": "24 Hours",
  "@recoveryM2Label": {},
  "recoveryM2Title": "Restoring Rhythm",
  "@recoveryM2Title": {},
  "recoveryM2Body": "For many people, the body's basic rhythms — heart rate, hydration, sleep — start to shift as it adjusts. This can feel calming for some and uncomfortable for others.",
  "@recoveryM2Body": {},
  "recoveryM2System": "Cardiovascular System",
  "@recoveryM2System": {},
  "recoveryM3Label": "48 Hours",
  "@recoveryM3Label": {},
  "recoveryM3Title": "The Pivot Point",
  "@recoveryM3Title": {},
  "recoveryM3Body": "For people who were drinking heavily, this can be one of the highest-risk windows for withdrawal symptoms. Your nervous system may feel overstimulated as it works to rebalance.",
  "@recoveryM3Body": {},
  "recoveryM3System": "Central Nervous System",
  "@recoveryM3System": {},
  "recoveryM4Label": "3 Days",
  "@recoveryM4Label": {},
  "recoveryM4Title": "Clearing the System",
  "@recoveryM4Title": {},
  "recoveryM4Body": "For many people, the most intense early physical adjustment begins to ease around this point, though recovery is individual and some symptoms can continue.",
  "@recoveryM4Body": {},
  "recoveryM4System": "Total Body",
  "@recoveryM4System": {},
  "recoveryM5Label": "1 Week",
  "@recoveryM5Label": {},
  "recoveryM5Title": "Deepening Rest",
  "@recoveryM5Title": {},
  "recoveryM5Body": "Restorative sleep often begins to return. Hydration, appetite, and daily energy may start to feel more stable, although sleep and mood can still fluctuate.",
  "@recoveryM5Body": {},
  "recoveryM5System": "Brain & Sleep Cycles",
  "@recoveryM5System": {},
  "recoveryM6Label": "2 Weeks",
  "@recoveryM6Label": {},
  "recoveryM6Title": "Finding Balance",
  "@recoveryM6Title": {},
  "recoveryM6Body": "Physical stamina may begin to return as sleep, appetite, hydration, and daily rhythm become more stable.",
  "@recoveryM6Body": {},
  "recoveryM6System": "Energy & Digestion",
  "@recoveryM6System": {},
  "recoveryM7Label": "1 Month",
  "@recoveryM7Label": {},
  "recoveryM7Title": "Meaningful Relief",
  "@recoveryM7Title": {},
  "recoveryM7Body": "Your body has had a meaningful stretch of relief from the strain of alcohol. Many people notice steadier energy, clearer thinking, and improved sleep around this stage.",
  "@recoveryM7Body": {},
  "recoveryM7System": "Liver & Vital Organs",
  "@recoveryM7System": {},
  "recoveryM8Label": "3 Months",
  "@recoveryM8Label": {},
  "recoveryM8Title": "Restoring Joy",
  "@recoveryM8Title": {},
  "recoveryM8Body": "Your body may feel more resilient as sleep, nourishment, movement, and reduced alcohol strain begin working together.",
  "@recoveryM8Body": {},
  "recoveryM8System": "Neurochemistry",
  "@recoveryM8System": {},
  "recoveryM9Label": "6 Months",
  "@recoveryM9Label": {},
  "recoveryM9Title": "True Resilience",
  "@recoveryM9Title": {},
  "recoveryM9Body": "Many people notice a steadier baseline by this stage. Stress may feel more manageable, sleep may feel more reliable.",
  "@recoveryM9Body": {},
  "recoveryM9System": "Nervous System",
  "@recoveryM9System": {},
  "recoveryM10Label": "1 Year",
  "@recoveryM10Label": {},
  "recoveryM10Title": "A New Baseline",
  "@recoveryM10Title": {},
  "recoveryM10Body": "For many people, the long-term load on energy, sleep, and mood is meaningfully lighter after a year without alcohol.",
  "@recoveryM10Body": {},
  "recoveryM10System": "Whole Body",
  "@recoveryM10System": {},
  "recoveryM11Label": "2 Years & Beyond",
  "@recoveryM11Label": {},
  "recoveryM11Title": "Lasting Vitality",
  "@recoveryM11Title": {},
  "recoveryM11Body": "The benefits of reduced alcohol strain can continue to deepen over time, supporting your body, mind, relationships, and daily sense of stability.",
  "@recoveryM11Body": {},
  "recoveryM11System": "Whole Body Renewal",
  "@recoveryM11System": {},
