  "@homeHeroQuote11": {"description": "Rotating daily hero line on the home Serenity card (12 of 50)."},
  "homeHeroQuote12": "Discipline becomes identity.",
  "@homeHeroQuote12": {"description": "Rotating daily hero line on the home Serenity card (13 of 50)."},
  "homeHeroQuote13": "You're rewriting the story.",
  "@homeHeroQuote13": {"description": "Rotating daily hero line on the home Serenity card (14 of 50)."},
  "homeHeroQuote14": "The next right choice is the whole game.",
  "@homeHeroQuote14": {"description": "Rotating daily hero line on the home Serenity card (15 of 50)."},
  "homeHeroQuote15": "Show up. The rest follows.",
  "@homeHeroQuote15": {"description": "Rotating daily hero line on the home Serenity card (16 of 50)."},
  "homeHeroQuote16": "Old life. New chapter.",
  "@homeHeroQuote16": {"description": "Rotating daily hero line on the home Serenity card (17 of 50)."},
  "homeHeroQuote17": "You did the hard thing today.",
  "@homeHeroQuote17": {"description": "Rotating daily hero line on the home Serenity card (18 of 50)."},
  "homeHeroQuote18": "Progress isn't loud. It's daily.",
  "@homeHeroQuote18": {"description": "Rotating daily hero line on the home Serenity card (19 of 50)."},
  "homeHeroQuote19": "Better is built, not found.",
  "@homeHeroQuote19": {"description": "Rotating daily hero line on the home Serenity card (20 of 50)."},
  "homeHeroQuote20": "Today is the receipt.",
  "@homeHeroQuote20": {"description": "Rotating daily hero line on the home Serenity card (21 of 50)."},
  "homeHeroQuote21": "You moved the needle.",
  "@homeHeroQuote21": {"description": "Rotating daily hero line on the home Serenity card (22 of 50)."},
  "homeHeroQuote22": "Sobriety is the work and the reward.",
  "@homeHeroQuote22": {"description": "Rotating daily hero line on the home Serenity card (23 of 50)."},
  "homeHeroQuote23": "What you do daily defines you.",
  "@homeHeroQuote23": {"description": "Rotating daily hero line on the home Serenity card (24 of 50)."},
  "homeHeroQuote24": "Hours add to days. Days add to years.",
  "@homeHeroQuote24": {"description": "Rotating daily hero line on the home Serenity card (25 of 50)."},
  "homeHeroQuote25": "You're closer than you were.",
  "@homeHeroQuote25": {"description": "Rotating daily hero line on the home Serenity card (26 of 50)."},
  "homeHeroQuote26": "The first hard choice is behind you.",
  "@homeHeroQuote26": {"description": "Rotating daily hero line on the home Serenity card (27 of 50)."},
  "homeHeroQuote27": "You're not who you were yesterday.",
  "@homeHeroQuote27": {"description": "Rotating daily hero line on the home Serenity card (28 of 50)."},
  "homeHeroQuote28": "Action over feeling. Always.",
  "@homeHeroQuote28": {"description": "Rotating daily hero line on the home Serenity card (29 of 50)."},
  "homeHeroQuote29": "Hard now. Easier later.",
  "@homeHeroQuote29": {"description": "Rotating daily hero line on the home Serenity card (30 of 50)."},
  "homeHeroQuote30": "You're stacking days.",
  "@homeHeroQuote30": {"description": "Rotating daily hero line on the home Serenity card (31 of 50)."},
  "homeHeroQuote31": "The streak doesn't lie.",
  "@homeHeroQuote31": {"description": "Rotating daily hero line on the home Serenity card (32 of 50)."},
  "homeHeroQuote32": "Choose forward. Choose again.",
  "@homeHeroQuote32": {"description": "Rotating daily hero line on the home Serenity card (33 of 50)."},
  "homeHeroQuote33": "You showed up. That's everything.",
  "@homeHeroQuote33": {"description": "Rotating daily hero line on the home Serenity card (34 of 50)."},
  "homeHeroQuote34": "Days like this are how it changes.",
  "@homeHeroQuote34": {"description": "Rotating daily hero line on the home Serenity card (35 of 50)."},
  "homeHeroQuote35": "You're building something real.",
  "@homeHeroQuote35": {"description": "Rotating daily hero line on the home Serenity card (36 of 50)."},
  "homeHeroQuote36": "Today is proof.",
  "@homeHeroQuote36": {"description": "Rotating daily hero line on the home Serenity card (37 of 50)."},
  "homeHeroQuote37": "Discipline is freedom.",
  "@homeHeroQuote37": {"description": "Rotating daily hero line on the home Serenity card (38 of 50)."},
  "homeHeroQuote38": "One choice. Then the next.",
  "@homeHeroQuote38": {"description": "Rotating daily hero line on the home Serenity card (39 of 50)."},
  "homeHeroQuote39": "The reps are the result.",
  "@homeHeroQuote39": {"description": "Rotating daily hero line on the home Serenity card (40 of 50)."},
  "homeHeroQuote40": "You're earning your future.",
  "@homeHeroQuote40": {"description": "Rotating daily hero line on the home Serenity card (41 of 50)."},
  "homeHeroQuote41": "Effort compounds quietly.",
  "@homeHeroQuote41": {"description": "Rotating daily hero line on the home Serenity card (42 of 50)."},
  "homeHeroQuote42": "Today's win is tomorrow's foundation.",
  "@homeHeroQuote42": {"description": "Rotating daily hero line on the home Serenity card (43 of 50)."},
  "homeHeroQuote43": "Forward is enough.",
  "@homeHeroQuote43": {"description": "Rotating daily hero line on the home Serenity card (44 of 50)."},
  "homeHeroQuote44": "You're not starting over. You're continuing.",
  "@homeHeroQuote44": {"description": "Rotating daily hero line on the home Serenity card (45 of 50)."},
  "homeHeroQuote45": "The work is the win.",
  "@homeHeroQuote45": {"description": "Rotating daily hero line on the home Serenity card (46 of 50)."},
  "homeHeroQuote46": "Strong is what you become.",
  "@homeHeroQuote46": {"description": "Rotating daily hero line on the home Serenity card (47 of 50)."},
  "homeHeroQuote47": "The hard days build you.",
  "@homeHeroQuote47": {"description": "Rotating daily hero line on the home Serenity card (48 of 50)."},
  "homeHeroQuote48": "Decision by decision. Day by day.",
  "@homeHeroQuote48": {"description": "Rotating daily hero line on the home Serenity card (49 of 50)."},
  "homeHeroQuote49": "You're doing it.",
  "@homeHeroQuote49": {"description": "Rotating daily hero line on the home Serenity card (50 of 50)."},
  "homeRecoveryBody0": "Your body begins adjusting. Hydration and rest are your allies right now.",
  "@homeRecoveryBody0": {"description": "Short healing-timeline body text on the home recovery banner for the 12-hour milestone."},
  "homeRecoveryBody1": "Heart rate and sleep patterns may begin to shift as your body finds its rhythm.",
  "@homeRecoveryBody1": {"description": "Short healing-timeline body text on the home recovery banner for the 24-hour milestone."},
  "homeRecoveryBody2": "A significant window — be patient with yourself. Seek support if anything feels unsafe.",
  "@homeRecoveryBody2": {"description": "Short healing-timeline body text on the home recovery banner for the 48-hour milestone."},
  "homeRecoveryBody3": "The most intense early adjustment may begin to ease. A small window of calm can emerge.",
  "@homeRecoveryBody3": {"description": "Short healing-timeline body text on the home recovery banner for the 3-day milestone."},
  "homeRecoveryBody4": "Restorative sleep often begins to return. Vivid dreams can be a sign of deep repair.",
  "@homeRecoveryBody4": {"description": "Short healing-timeline body text on the home recovery banner for the 1-week milestone."},
  "homeRecoveryBody5": "Physical stamina may begin to return. Concentration and memory are beginning to sharpen.",
  "@homeRecoveryBody5": {"description": "Short healing-timeline body text on the home recovery banner for the 2-week milestone."},
  "homeRecoveryBody6": "Many people describe a sense of physical relief settling in around this point.",
  "@homeRecoveryBody6": {"description": "Short healing-timeline body text on the home recovery banner for the 1-month milestone."},
  "homeRecoveryBody7": "Day-to-day satisfaction may slowly start to feel more accessible again.",
  "@homeRecoveryBody7": {"description": "Short healing-timeline body text on the home recovery banner for the 3-month milestone."},
  "homeRecoveryBody8": "Many people notice a steadier baseline. Urges may become less frequent and easier to move through.",
  "@homeRecoveryBody8": {"description": "Short healing-timeline body text on the home recovery banner for the 6-month milestone."},
  "homeRecoveryBody9": "For many people, the long-term load on sleep, energy, and mood begins to ease at this point.",
  "@homeRecoveryBody9": {"description": "Short healing-timeline body text on the home recovery banner for the 1-year milestone."},
  "homeRecoveryBody10": "The space you have created can continue to deepen over time — one ordinary day at a time.",
  "@homeRecoveryBody10": {"description": "Short healing-timeline body text on the home recovery banner for the 2-years-and-beyond milestone."},
  "homeRecoveryJustStarting": "Just Starting",
